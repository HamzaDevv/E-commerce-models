# Instamart ML Backend — Environment Configuration Template
# Copy this file to .env and fill in your actual keys.

# Google Gemini API Key (Required for LLM-based features)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Port configuration (Defaults to 8000)
# PORT=8000

# Optional: Host configuration (Defaults to 0.0.0.0)
# HOST=0.0.0.0
